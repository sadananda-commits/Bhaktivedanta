# ── Vedanta Learning Portal — Environment Variables ───────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Google Spreadsheet ID for the main student/staff data sheet
# Found in the sheet URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account credentials (recommended)
# Paste entire contents of your service account JSON key as a single line.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# SheetDB API endpoints (used for enrolment and CMS data)
SHEETDB_URL=https://sheetdb.io/api/v1/your_endpoint_here
SHEETDB_CMS_URL=https://sheetdb.io/api/v1/your_cms_endpoint_here

CHAT_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbzTVeLlFOhvZrJQm3eKvHOKbOhHfJpltaD-UbOB4z1V6jQJGKlPrZCMcOu28daD8_sdow/exec
